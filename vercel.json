{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "camp.cargopete.com" }],
      "destination": "https://engine.camp/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "camp.cargopete.com" }],
      "destination": "https://engine.camp/:path+",
      "permanent": true
    }
  ]
}
